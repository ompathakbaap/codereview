# ─── Database ───────────────────────────────────────────────
# Neon.tech → New Project → copy the connection string
DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxx.neon.tech/codereview?sslmode=require

# ─── Redis ──────────────────────────────────────────────────
# Upstash → Create Redis → copy Redis URL
REDIS_URL=rediss://:token@xxx.upstash.io:6379

# ─── Groq (free tier, no credit card) ──────────────────────
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile

# ─── App ────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-string-in-production
FRONTEND_URL=http://localhost:3000

# ─── GitHub (optional) ──────────────────────────────────────
# Needed for private repos + avoids unauthenticated rate limits
GITHUB_TOKEN=
